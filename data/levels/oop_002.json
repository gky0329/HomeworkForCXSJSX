{
  "id": "oop_002",
  "title": "多类多实例",
  "type": "challenge",
  "unit": 1,
  "order": 2,
  "prerequisites": ["oop_001"],

  "npc_dialogue": [
    {"npc": "villager", "text": "村里不止有村民，还有铁傀儡、僵尸和骷髅。每种生物都是一类对象。"},
    {"npc": "iron_golem", "text": "不同的类可以同时存在，每个类都能创建多个实例。"}
  ],

  "questions": [
    {
      "id": "q1", "type": "single_choice",
      "prompt": "一个程序里可以定义几个不同的 class？",
      "options": [
        {"id": "A", "text": "只能 1 个"},
        {"id": "B", "text": "可以有多个，用不同名字区分"},
        {"id": "C", "text": "只能和文件数量相同"},
        {"id": "D", "text": "不能超过 main 函数的行数"}
      ],
      "answer": "B"
    },
    {
      "id": "q2", "type": "single_choice",
      "prompt": "两个不同的类，它们的对象之间的成员值会互相影响吗？",
      "options": [
        {"id": "A", "text": "会，所有对象共享同一份成员值"},
        {"id": "B", "text": "不会，每个实例拥有独立的成员值"},
        {"id": "C", "text": "只有同名的成员会互相影响"},
        {"id": "D", "text": "取决于当时的内存大小"}
      ],
      "answer": "B"
    },
    {
      "id": "q3", "type": "single_choice",
      "prompt": "Creeper c; IronGolem g; — 这两个变量分别是什么？",
      "options": [
        {"id": "A", "text": "两个同类型的变量"},
        {"id": "B", "text": "两个类定义"},
        {"id": "C", "text": "c 是 Creeper 类的实例，g 是 IronGolem 类的实例"},
        {"id": "D", "text": "两个语法错误"}
      ],
      "answer": "C"
    }
  ],

  "theory": "C++ 中可以在同一个作用域里定义多个类，每个类都可以创建多个对象实例。不同的类通过类名区分，对象通过变量名区分。就像村里同时有村民和铁傀儡，每种都有各自的数量和属性。",

  "key_points": [
    "同一作用域可定义多个类",
    "每个类可创建多个独立的对象实例",
    "不同对象的成员值互不影响"
  ],

  "initial_code": [
    "____ Creeper {",
    "public:",
    "    int health;",
    "};",
    "____ IronGolem {",
    "public:",
    "    int health;",
    "};",
    "Creeper c;",
    "IronGolem g;",
    "c.health = ____;",
    "g.health = 50;"
  ],

  "blanks": [
    { "line": 0, "type": "text_input", "placeholder": "class", "width_chars": 8, "validator": "cpp_keyword" },
    { "line": 4, "type": "text_input", "placeholder": "class", "width_chars": 8, "validator": "cpp_keyword" },
    { "line": 10, "type": "text_input", "placeholder": "30", "width_chars": 6, "validator": "number" }
  ],

  "goal": {
    "checks": [
      { "type": "class_exists", "name": "Creeper" },
      { "type": "class_exists", "name": "IronGolem" },
      { "type": "instance_exists", "var_name": "c", "class_name": "Creeper" },
      { "type": "instance_exists", "var_name": "g", "class_name": "IronGolem" },
      { "type": "member_value_equals", "var_name": "c", "member": "health", "value": 30 },
      { "type": "member_value_equals", "var_name": "g", "member": "health", "value": 50 },
      { "type": "instance_count", "class_name": "Creeper", "count": 1 },
      { "type": "instance_count", "class_name": "IronGolem", "count": 1 },
      { "type": "no_errors" }
    ]
  },

  "hints": [
    "用 class 关键字定义类",
    "Creeper 的 health 应该设为 30",
    "IronGolem 的 health 应该设为 50"
  ],

  "success_message": "完美！你同时创建了 Creeper 和 IronGolem 两个类的实例，并正确设置了各自的 health 值。",
  "failure_guidance": "检查两个类的 class 关键字是否都正确，health 值是否分别设置为 30 和 50。",

  "code_line_notes": [
    "定义 Creeper 类",
    "",
    "Creeper 的 health 成员",
    "",
    "定义 IronGolem 类",
    "",
    "",
    "",
    "创建 Creeper 实例 c",
    "创建 IronGolem 实例 g",
    "设置 c 的 health 为 30",
    "设置 g 的 health 为 50"
  ],

  "estimated_time_min": 5
}
