    { "line": 5, "type": "text_input", "placeholder": "health", "width_chars": 10, "validator": "identifier" }
  ],
  "goal": {
    "checks": [
      { "type": "class_exists", "name": "Player" },
      { "type": "class_has_member", "class_name": "Player", "member_name": "health" },
