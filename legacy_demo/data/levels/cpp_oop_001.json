{
  "id": "cpp_oop_001",
  "title": "C++ 第一关：类和对象",
  "npc_dialogue": [
    {
      "npc": "villager",
      "text": "欢迎来到方块村。类就像蓝图，告诉我们一类方块应该有哪些数据和行为。"
    },
    {
      "npc": "iron_golem",
      "text": "对象是按照蓝图生成出来的具体实例。像每一个铁傀儡都有自己的生命值和位置。"
    },
    {
      "npc": "villager",
      "text": "通过这一关，你会识别 class、成员变量、成员函数和对象创建。"
    }
  ],
  "questions": [
    {
      "id": "q1",
      "type": "single_choice",
      "prompt": "在 C++ 中，class 最接近 Minecraft 里的哪一种概念？",
      "options": [
        {"id": "A", "text": "一个具体放在地上的方块"},
        {"id": "B", "text": "描述一类对象如何生成和行动的蓝图"},
        {"id": "C", "text": "游戏窗口的分辨率"},
        {"id": "D", "text": "玩家背包里的随机物品"}
      ],
      "answer": "B"
    },
    {
      "id": "q2",
      "type": "single_choice",
      "prompt": "下面哪一项是对象？",
      "options": [
        {"id": "A", "text": "class Zombie"},
        {"id": "B", "text": "int health;"},
        {"id": "C", "text": "Zombie z1;"},
        {"id": "D", "text": "public:"}
      ],
      "answer": "C"
    },
    {
      "id": "q3",
      "type": "single_choice",
      "prompt": "成员函数通常用来表示什么？",
      "options": [
        {"id": "A", "text": "对象能执行的行为"},
        {"id": "B", "text": "编译器版本"},
        {"id": "C", "text": "源文件大小"},
        {"id": "D", "text": "命名空间的颜色"}
      ],
      "answer": "A"
    },
    {
      "id": "q4",
      "type": "single_choice",
      "prompt": "public 访问控制通常表示什么？",
      "options": [
        {"id": "A", "text": "只能在类内部访问"},
        {"id": "B", "text": "可以被类外代码访问"},
        {"id": "C", "text": "对象不能创建"},
        {"id": "D", "text": "变量会自动变成字符串"}
      ],
      "answer": "B"
    },
    {
      "id": "q5",
      "type": "single_choice",
      "prompt": "构造函数的主要作用是什么？",
      "options": [
        {"id": "A", "text": "销毁程序"},
        {"id": "B", "text": "初始化新创建的对象"},
        {"id": "C", "text": "替换操作系统"},
        {"id": "D", "text": "只负责输出换行"}
      ],
      "answer": "B"
    },
    {
      "id": "q6",
      "type": "code_fill_blank",
      "prompt": "补全代码：声明一个名为 Player 的类。",
      "code": "____ Player {\npublic:\n    int health;\n};",
      "candidates": ["class", "object", "new", "include"],
      "answer": "class"
    },
    {
      "id": "q7",
      "type": "code_fill_blank",
      "prompt": "补全代码：创建一个 Player 对象 steve。",
      "code": "class Player {\npublic:\n    int health;\n};\n\nint main() {\n    ____ steve;\n}",
      "candidates": ["Player", "class", "public", "void"],
      "answer": "Player"
    },
    {
      "id": "q8",
      "type": "code_fill_blank",
      "prompt": "补全代码：给对象 steve 的 health 成员赋值。",
      "code": "Player steve;\nsteve.____ = 20;",
      "candidates": ["health", "Player", "public", "main"],
      "answer": "health"
    }
  ]
}
